#!/bin/bash

if [[ $# -lt 1 ]]; then
  echo "Usage: runm <target[,target...]> [project...] [additional args...]"
  exit 1
fi

target="$1"
shift

projects=()
while [[ $# -ge 1 && "$1" != -* ]]; do
  projects+=("$1")
  shift
done

if [[ ${#projects[@]} -gt 0 ]]; then
  project=$(IFS=,; echo "${projects[*]}")
  npx nx run-many -t "$target" -p "$project" "$@"
else
  npx nx run-many -t "$target" "$@"
fi
