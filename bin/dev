#!/bin/bash

firstArg=$1

if [ -z "$firstArg" ]; then
  echo "Usage: dev <branch> [additional yarn dev args]"
  exit 1
fi

allArgs=("$@")
restArgs=("${allArgs[@]:1}")

cd ~/code/mediatool/master/webapp/
branch=$1
git fetch
git checkout $branch
git reset --hard origin/$branch
run dev "${restArgs[@]}"
